{
  "name": "video-pipeline",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "remotion studio",
    "build": "tsc",
    "test": "jest --passWithNoTests",
    "api": "tsx src/api/server.ts",
    "pilot": "tsx scripts/generate-pilot.ts",
    "thumbnail": "tsx scripts/generate-thumbnail.ts",
    "render": "remotion render src/compositions/index.tsx LongVideo --concurrency=6",
    "render:4k": "remotion render src/compositions/index.tsx LongVideo4K --concurrency=4",
    "render:4k-upscale": "remotion render src/compositions/index.tsx LongVideo --scale=2 --concurrency=4",
    "render:fast": "remotion render src/compositions/index.tsx LongVideo --concurrency=10 --jpeg-quality=75",
    "render:all": "tsx scripts/render-all.ts",
    "render:all:fast": "tsx scripts/render-all.ts --fast",
    "render:topic": "tsx scripts/render-topic.ts",
    "render:session": "tsx scripts/render-session.ts",
    "render:shorts": "tsx scripts/render-viral-shorts.ts",
    "make:reels": "tsx scripts/make-reels.ts",
    "render:vertical": "remotion render src/compositions/index.tsx VerticalLong --concurrency=6",
    "render:vertical:session": "tsx scripts/render-vertical-session.ts",
    "render:vertical:batch": "bash scripts/batch-render-vertical.sh",
    "metadata:all": "tsx scripts/generate-session-metadata.ts",
    "publish:queue:generate": "tsx scripts/generate-publish-queue.ts",
    "publish:queue:status": "tsx scripts/get-next-publish.ts --status",
    "publish:next": "tsx scripts/get-next-publish.ts --force",
    "publish:verify": "tsx scripts/verify-publish-setup.ts",
    "publish:verify:videos": "tsx scripts/verify-publish-setup.ts --check-videos",
    "publish:youtube": "tsx scripts/publish-to-youtube.ts",
    "publish:instagram": "tsx scripts/publish-to-instagram.ts",
    "dev": "concurrently \"npm start\" \"npm run api\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@remotion/cli": "^4.0.441",
    "@remotion/google-fonts": "^4.0.441",
    "@remotion/lottie": "^4.0.441",
    "@remotion/paths": "^4.0.441",
    "@remotion/renderer": "^4.0.441",
    "@remotion/transitions": "^4.0.441",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "edge-tts-node": "^1.5.7",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "lottie-web": "^5.13.0",
    "lucide-react": "^1.8.0",
    "node-cache": "^5.1.2",
    "noisejs": "^2.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-terminal-ui": "^1.4.0",
    "remotion": "^4.0.441",
    "roughjs": "^4.6.6",
    "say": "^0.16.0",
    "shiki": "^4.0.2",
    "simple-icons": "^16.14.0"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "~5.7.0"
  }
}
